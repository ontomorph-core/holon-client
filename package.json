{
  "name": "@holon/client",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript client for the HOLON clinical knowledge API — concepts, drug interactions, cross-vocabulary mappings, reference ranges, and phenotype similarity.",
  "license": "UNLICENSED",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@holon/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
